// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────
model User {
  id          String   @id @default(cuid())
  username    String   @unique                // "john_doe"
  displayName String                          // "John Doe"
  password    String                          // bcrypt hash
  role        String   @default("MEMBER")     // "VISITOR", "MEMBER", "ADMIN"
  avatarUrl   String?
  bio         String?
  githubUrl   String?
  linkedinUrl String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  projectMemberships ProjectMember[]
  leaderboardEntry   LeaderboardEntry?
  uploadedMaterials  StudyMaterial[]
  createdEvents      Event[]
  submittedProjects  Project[]         @relation("Submitter")
}

// ─────────────────────────────────────────────
// PROJECT
// ─────────────────────────────────────────────
model Project {
  id            String        @id @default(cuid())
  title         String
  description   String        @db.Text
  techStack     String?       // "Python, OpenCV, React"
  githubUrl     String?
  demoUrl       String?
  thumbnailUrl  String?
  status        String        @default("ONGOING") // "COMPLETED", "ONGOING", "IDLE", "DEAD"
  isPinned      Boolean       @default(false)   // admin-only, never exposed to public
  isApproved    Boolean       @default(false)   // false until admin approves
  sortOrder     Int           @default(0)       // for future manual ordering
  submittedById String
  submittedBy   User          @relation("Submitter", fields: [submittedById], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  members       ProjectMember[]
}

// ─────────────────────────────────────────────
// PROJECT MEMBERS (join table)
// ─────────────────────────────────────────────
model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  userId    String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])   // prevent duplicate membership
}

// ─────────────────────────────────────────────
// LEADERBOARD (separate table as spec'd)
// ─────────────────────────────────────────────
model LeaderboardEntry {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  points      Int      @default(0)
  // projectCount is computed from JOIN — not stored
  lastUpdated DateTime @updatedAt
}

// ─────────────────────────────────────────────
// EVENTS
// ─────────────────────────────────────────────
model Event {
  id          String    @id @default(cuid())
  title       String
  description String    @db.Text
  eventDate   DateTime
  location    String?                     // "Room 302, CSE Block" or "Online"
  imageUrl    String?
  registrationUrl String?
  isPublished Boolean   @default(false)
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─────────────────────────────────────────────
// STUDY MATERIALS
// ─────────────────────────────────────────────
model StudyMaterial {
  id          String            @id @default(cuid())
  title       String
  description String?
  fileUrl     String?
  externalUrl String?
  category    String            // "ROADMAP", "PAPER", "TUTORIAL", "RESOURCE", "OTHER"
  status      String            @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  uploadedById String
  uploadedBy  User              @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
}

// ─────────────────────────────────────────────
// SITE STATS (admin-editable homepage counters)
// ─────────────────────────────────────────────
model SiteStats {
  id                 String @id @default("singleton") // Only one row, always id="singleton"
  projectsCount      Int    @default(0)
  bootcampsOrganized Int    @default(0)
  activeMembers      Int    @default(0)
  societyMembers     Int    @default(0)
  updatedAt          DateTime @updatedAt
}
